# Required
CENTREON_HOST=https://centreon.example.com
CENTREON_USERNAME=admin
CENTREON_PASSWORD=

# Optional: API token (alternative to username/password)
# CENTREON_TOKEN=

# Optional
CENTREON_ALLOW_SELF_SIGNED=false
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=8080
MCP_HTTP_HOST=0.0.0.0
AUTH_MODE=env
LOG_LEVEL=info
